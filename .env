DATABASE_URL=file:/home/z/my-project/db/custom.db

# ══════════════════════════════════════════════════════════════════════════
# OpenAI (ChatGPT) — PRIMARY AI Provider  ⭐ RECOMMENDED
# ══════════════════════════════════════════════════════════════════════════
# To use ChatGPT (GPT-4o Vision + DALL-E 3), add your OpenAI API key below.
# Get your API key at: https://platform.openai.com/api-keys
# The key must start with "sk-" (e.g., sk-proj-xxxxxxxxxxxxx)
#
# ⚠️ IMPORTANT: Your OpenAI account needs credits to work!
#    If you get "429 insufficient_quota", add billing at:
#    https://platform.openai.com/account/billing
#    $5 USD gives you thousands of image generations.
#
# Once configured, the app will use:
#   - GPT-4o Vision for furniture image analysis (copilot analysis)
#   - DALL-E 3 for photorealistic ficha image generation
#   - DALL-E 3 for individual view generation (front, side, top, perspective)
#
# Leave blank/unset to use other providers as fallback.
# ══════════════════════════════════════════════════════════════════════════
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

# ══════════════════════════════════════════════════════════════════════════
# Azure OpenAI — SECONDARY AI Provider
# ══════════════════════════════════════════════════════════════════════════
# Uses Microsoft Azure OpenAI Service (GPT-4o Vision + DALL-E 3).
#
# ⚠️ IMPORTANT: Deployment names must EXACTLY match your Azure resource!
#    If you get "404 DeploymentNotFound", check your deployment names in:
#    Azure Portal → Azure AI Studio → Deployments
#    Then set AZURE_OPENAI_DEPLOYMENT_NAME and AZURE_OPENAI_DALLE_DEPLOYMENT
#    to the EXACT names shown in Azure (they may differ from "gpt-4o" or "dall-e-3")
#
# Steps to configure:
#   1. Create Azure OpenAI resource in Azure Portal
#   2. Deploy GPT-4o model (note the deployment name!)
#   3. Deploy DALL-E 3 model (note the deployment name!)
#   4. Copy endpoint and key from Azure Portal
#   5. Set all env vars below
# ══════════════════════════════════════════════════════════════════════════
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2025-04-01-preview
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o         ← YOUR ACTUAL deployment name from Azure!
# AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o        ← Same as above if same deployment
# AZURE_OPENAI_DALLE_DEPLOYMENT=dall-e-3       ← YOUR ACTUAL DALL-E deployment name from Azure!

# ══════════════════════════════════════════════════════════════════════════
# Gemini — TERTIARY AI Provider
# ══════════════════════════════════════════════════════════════════════════
# Uses Google Gemini 2.0 Flash for text/vision analysis.
# ⚠️ Free tier has very limited quota (often 0 requests allowed).
#    Upgrade at https://ai.google.dev/pricing for paid tier.
# ══════════════════════════════════════════════════════════════════════════
# GEMINI_API_KEY=

