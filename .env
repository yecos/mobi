DATABASE_URL=file:/home/z/my-project/db/custom.db

# ══════════════════════════════════════════════════════════════════════════
# OpenAI (ChatGPT) — PRIMARY AI Provider
# ══════════════════════════════════════════════════════════════════════════
# To use ChatGPT (GPT-4o Vision + DALL-E 3), add your OpenAI API key below.
# Get your API key at: https://platform.openai.com/api-keys
# The key must start with "sk-" (e.g., sk-proj-xxxxxxxxxxxxx)
#
# Once configured, the app will use:
#   - GPT-4o Vision for furniture image analysis (copilot analysis)
#   - DALL-E 3 for photorealistic ficha image generation
#   - DALL-E 3 for individual view generation (front, side, top, perspective)
#
# Leave blank/unset to use Z-AI as fallback provider.
# ══════════════════════════════════════════════════════════════════════════
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_IMAGE_MODEL=dall-e-3

# ══════════════════════════════════════════════════════════════════════════
